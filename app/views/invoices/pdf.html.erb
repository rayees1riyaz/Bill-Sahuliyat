<div class="invoice-container">
  <div class="flex justify-between items-start border-b-2 border-gray-900 pb-4 mb-6">
    <div>
      <h1 class="text-3xl font-black uppercase">SAADAT ENTERPRISES</h1>
      <p class="font-bold text-sm">OLD ALI JAN ROAD ZOONIMAR SRINAGAR 190011</p>
      <p class="text-xs mt-1"><strong>Deals With:</strong> HOME APPLIANCES, MOBILES, LAPTOPS, SOLAR, SEWING MACHINE, AC</p>
      <p class="text-xs">INVERTERS BATTERIES, LED, SECOND HAND MOBILES, DEEP FREEZERS & PRINTERS ETC.</p>
      <p class="text-xs mt-1">Email: saadatenterprises0@gmail.com | Phone: 9906776815 / 9906871563</p>
      <p class="mt-2 font-bold text-xs border border-gray-900 inline-block px-2 py-1">GSTIN: 01BFFPR8956F2Z8</p>
    </div>
    <div class="text-right">
      <h2 class="text-2xl font-black">TAX INVOICE</h2>
      <p class="text-sm mt-2"><strong>Invoice No:</strong> <%= @invoice.invoice_number %></p>
      <p class="text-sm"><strong>Date:</strong> <%= @invoice.invoice_date.strftime("%d/%m/%Y") %></p>
      <% if @invoice.financed_by.present? %>
        <p class="text-sm"><strong>Financed By:</strong> <%= @invoice.financed_by %></p>
      <% end %>
    </div>
  </div>

  <div class="mb-6">
    <h3 class="font-bold text-gray-700 text-sm uppercase mb-2 border-b border-gray-300 pb-1 inline-block">Billed To:</h3>
    <p class="text-lg font-bold text-black"><%= @invoice.customer_name %></p>
    <div class="flex mt-2">
      <div class="w-1/2 pr-4">
        <p class="text-sm whitespace-pre-line italic"><%= @invoice.customer_address %></p>
      </div>
      <div class="w-1/2 pl-4 border-l border-gray-300 text-sm">
        <% if @invoice.customer_phone.present? %>
          <p><strong>Phone:</strong> <%= @invoice.customer_phone %></p>
        <% end %>
        <% if @invoice.customer_email.present? %>
          <p><strong>Email:</strong> <%= @invoice.customer_email %></p>
        <% end %>
        <% if @invoice.customer_gstin.present? %>
          <p class="mt-1 pt-1 border-t border-gray-200"><strong>GSTIN:</strong> <%= @invoice.customer_gstin %></p>
        <% end %>
      </div>
    </div>
  </div>

  <table class="w-full text-sm mb-6">
    <thead>
      <tr>
        <th class="w-10 text-center">S.No</th>
        <th>Description of Goods</th>
        <th class="w-16">HSN</th>
        <th class="w-12 text-center">Qty</th>
        <th class="w-20 text-right">Rate</th>
        <th class="w-20 text-right">Amount</th>
        <th class="w-16 text-center">CGST</th>
        <th class="w-16 text-center">SGST</th>
        <th class="w-24 text-right">Total</th>
      </tr>
    </thead>
    <tbody>
      <% @invoice.line_items.each_with_index do |item, index| %>
        <tr>
          <td class="text-center"><%= index + 1 %></td>
          <td>
            <%= item.description %>
            <% if item.serial_number.present? %>
              <div class="text-xs text-gray-600 mt-1">S.NO/IMEI: <%= item.serial_number %></div>
            <% end %>
          </td>
          <td><%= item.hsn_code %></td>
          <td class="text-center"><%= item.quantity %></td>
          <td class="text-right"><%= number_to_currency(item.rate, unit: "", precision: 0) %></td>
          <td class="text-right"><%= number_to_currency(item.amount, unit: "", precision: 0) %></td>
          <td class="text-center">
            <%= item.cgst_rate %>%<br>
            <span class="text-xs"><%= number_to_currency(item.cgst_amount, unit: "", precision: 0) %></span>
          </td>
          <td class="text-center">
            <%= item.sgst_rate %>%<br>
            <span class="text-xs"><%= number_to_currency(item.sgst_amount, unit: "", precision: 0) %></span>
          </td>
          <td class="text-right font-bold"><%= number_to_currency(item.amount + item.cgst_amount + item.sgst_amount, unit: "", precision: 0) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="flex justify-end mb-8">
    <div class="w-64">
      <div class="flex justify-between py-1 text-sm border-b border-gray-100">
        <span>Sub Total:</span>
        <span><%= number_to_currency(@invoice.sub_total, unit: "₹", precision: 0) %></span>
      </div>
      <div class="flex justify-between py-1 text-sm border-b border-gray-100">
        <span>CGST Total:</span>
        <span><%= number_to_currency(@invoice.cgst_total, unit: "₹", precision: 0) %></span>
      </div>
      <div class="flex justify-between py-1 text-sm border-b border-gray-300">
        <span>SGST Total:</span>
        <span><%= number_to_currency(@invoice.sgst_total, unit: "₹", precision: 0) %></span>
      </div>
      <div class="flex justify-between py-2 text-lg font-black">
        <span>Grand Total:</span>
        <span><%= number_to_currency(@invoice.grand_total, unit: "₹", precision: 0) %></span>
      </div>
    </div>
  </div>

  <div class="flex justify-between text-xs mt-12 pt-4 border-t border-gray-300">
    <div class="w-1/2">
      <h4 class="font-bold mb-1">Terms & Conditions:</h4>
      <ul class="list-disc pl-4 space-y-1 text-gray-600 mb-4">
        <li>Item prices are liable without notice price and specification on the date of delivery.</li>
        <li>Items once sold cannot be taken back.</li>
        <li>Check items before deliver at our showroom or go down.</li>
      </ul>
      <h4 class="font-bold mb-1">Bank Details:</h4>
      <div class="flex space-x-4">
        <div>
          <p><strong>Bank:</strong> Axis Bank</p>
          <p><strong>Account:</strong> 922020063771960</p>
          <p><strong>IFSC:</strong> utib0004849</p>
        </div>
        <div>
          <p><strong>Bank:</strong> JK Bank</p>
          <p><strong>Account:</strong> 0185011110000118</p>
          <p><strong>IFSC:</strong> Jaka0sathoo</p>
        </div>
      </div>
    </div>
    <div class="w-1/4 text-center">
      <div class="h-24"></div>
      <p class="border-t border-gray-400 pt-2 font-bold">Authorized Signature</p>
      <p class="text-[10px] uppercase mt-1">For Saadat Enterprises</p>
    </div>
  </div>
</div>
